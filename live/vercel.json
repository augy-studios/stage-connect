{
    "$schema": "https://openapi.vercel.sh/vercel.json",
    "version": 2,
    "cleanUrls": true,
    "regions": ["sin1"],
    "routes": [{
            "src": "/api/(.*)",
            "dest": "/api/$1"
        },
        {
            "src": "^/$",
            "dest": "/public/index.html"
        },
        {
            "src": "^/live\\.html$",
            "dest": "/public/live.html"
        },
        {
            "src": "^/live\\.css$",
            "dest": "/public/live.css"
        },
        {
            "src": "^/live\\.js$",
            "dest": "/public/live.js"
        },
        {
            "src": "^/manifest\\.json$",
            "dest": "/public/manifest.json"
        },
        {
            "src": "^/[a-zA-Z0-9_-]+$",
            "dest": "/public/live.html"
        }
    ]
}